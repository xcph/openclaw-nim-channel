{
  "name": "openclaw-nim",
  "version": "1.0.3",
  "type": "module",
  "description": "OpenClaw NIM (NetEase IM) channel plugin",
  "license": "MIT",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "CHANGELOG.md"
  ],
  "keywords": [
    "openclaw",
    "nim",
    "netease",
    "yunxin",
    "im",
    "chatbot",
    "ai"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "nim",
      "label": "NIM",
      "selectionLabel": "NetEase IM (网易云信)",
      "docsPath": "/channels/nim",
      "docsLabel": "nim",
      "blurb": "网易云信 IM 即时通讯。",
      "aliases": [
        "netease",
        "yunxin"
      ],
      "order": 80
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@yxim/nim-bot": "^10.9.78",
    "zod": "^4.3.6"
  },
  "bundledDependencies": [
    "@yxim/nim-bot",
    "zod"
  ],
  "devDependencies": {
    "@types/node": "^25.0.10",
    "openclaw": "^2026.3.31",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
